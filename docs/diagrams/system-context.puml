@startuml system-context
!include <C4/C4_Context.puml>

title System Context – Copilot Agentic Playground

Person(user, "Developer / User", "Interacts with the system via browser and REST API")

System(system, "Copilot Agentic Playground", "Spring Boot + React app that demonstrates agentic patterns, stores greeting logs")

